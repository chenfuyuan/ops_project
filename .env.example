# Application runtime
PERSON_UP_APP_ENV=local

# Core infrastructure
PERSON_UP_DATABASE_URL=sqlite+pysqlite:///:memory:
PERSON_UP_REDIS_URL=redis://redis:6379/0
PERSON_UP_CELERY_BROKER_URL=redis://redis:6379/0
PERSON_UP_CELERY_RESULT_BACKEND=redis://redis:6379/1
PERSON_UP_OBJECT_STORAGE_ENDPOINT_URL=http://localhost:9000
PERSON_UP_OBJECT_STORAGE_BUCKET=person-up

# AI gateway config used by /ai-gateway/availability and AiGatewayFacade.generate().
# The config file defines providers, models, profiles, and the env var name for the API key.
AI_GATEWAY_CONFIG_PATH=/app/config/ai_gateway.json
AI_GATEWAY_API_KEY=replace-locally-do-not-commit
